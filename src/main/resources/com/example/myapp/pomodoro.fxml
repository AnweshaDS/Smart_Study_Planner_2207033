<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@style.css"
            fx:controller="com.example.myapp.PomodoroController">

    <!-- TOP -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header-bar">
            <padding>
                <Insets bottom="10" left="22" right="22" top="10"/>
            </padding>
            <Label fx:id="taskTitleLabel" styleClass="header-title" text="Task Name"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#onBack" text="Back" styleClass="back-btn"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox alignment="CENTER" spacing="14" styleClass="running-panel">
            <Label fx:id="modeLabel" styleClass="subtitle" text="STUDY"/>
            <Label fx:id="timerLabel" styleClass="timer-label" text="00:00:00"/>
        </VBox>
    </center>

    <!-- BOTTOM -->
    <bottom>
        <HBox alignment="CENTER" spacing="16" styleClass="footer-bar">
            <padding><Insets bottom="10" top="10"/></padding>
            <Button onAction="#pause" text="Pause" styleClass="action-btn"/>
            <Button onAction="#finish" text="Finish" styleClass="action-btn"/>
        </HBox>
    </bottom>

</BorderPane>