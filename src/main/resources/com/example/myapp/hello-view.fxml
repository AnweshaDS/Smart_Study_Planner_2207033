<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@style.css"
            fx:controller="com.example.myapp.HelloController">

    <top>
        <HBox spacing="10" styleClass="header-bar">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Smart Study Planner" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="taskInput" promptText="Enter a task..." HBox.hgrow="ALWAYS"/>
            <Button text="Add Task" onAction="#onAddTask" styleClass="action-btn"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="14" styleClass="running-panel">
            <Label text="Tasks" styleClass="subtitle"/>
            <ListView fx:id="taskList" prefWidth="600" prefHeight="360" styleClass="task-list"/>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="14" alignment="CENTER" styleClass="footer-bar">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Study seconds:" styleClass="subtitle"/>
            <TextField fx:id="timerInput" promptText="e.g. 1500" prefWidth="80"/>
            <Button text="Set Timer" onAction="#onSetTimer" styleClass="action-btn"/>
            <Label fx:id="timerLabel" text="00:00" styleClass="header-title"/>
            <Button text="Start" onAction="#onStartTask" styleClass="action-btn"/>
            <Button text="Pause" onAction="#onPauseTask" styleClass="back-btn"/>
            <Button text="Finish" onAction="#onFinishTask" styleClass="action-btn"/>
        </HBox>
    </bottom>

</BorderPane>