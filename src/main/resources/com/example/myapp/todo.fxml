<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@style.css"
            fx:controller="com.example.myapp.TodoController">

    <!-- TOP -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header-bar">
            <padding>
                <Insets top="10" bottom="10" left="22" right="22"/>
            </padding>

            <Label text="TODO Tasks" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Back" onAction="#onBack" styleClass="back-btn"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="11" styleClass="running-panel">
            <!-- INPUT ROW -->
            <HBox spacing="8">
                <TextField fx:id="titleField"
                           promptText="Task title"
                           HBox.hgrow="ALWAYS"/>

                <TextField fx:id="targetField"
                           promptText="Target HH:MM:SS"
                           prefWidth="100"/>
                <TextField fx:id="studyField"
                           promptText="Study HH:MM:SS"
                           prefWidth="100"/>
                <TextField fx:id="breakField"
                           promptText="Break HH:MM:SS"
                           prefWidth="100"/>
                <Button text="Add Task" onAction="#onAddTask" styleClass="action-btn"/>
            </HBox>

            <!-- LIST -->
            <ListView fx:id="todoList"
                      VBox.vgrow="ALWAYS"
                      styleClass="task-list"/>
        </VBox>
    </center>

    <!-- BOTTOM -->
    <bottom>
        <HBox alignment="CENTER" spacing="13" styleClass="footer-bar">
            <padding><Insets top="10" bottom="10"/></padding>
            <Button text="Start" onAction="#onStart" styleClass="action-btn"/>
            <Button text="Delete" onAction="#onDelete" styleClass="delete-btn"/>
        </HBox>
    </bottom>
</BorderPane>