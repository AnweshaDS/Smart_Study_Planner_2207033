<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@style.css"
            fx:controller="com.example.myapp.PausedController">

    <!-- TOP -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header-bar">
            <padding>
                <Insets bottom="10" left="22" right="22" top="10"/>
            </padding>
            <Label styleClass="header-title" text="Paused Tasks"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#onBack" text="Back" styleClass="back-btn"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="running-panel">
            <Label text="Select a Paused Task to Run, Finish, or Delete" styleClass="subtitle"/>
            <ListView fx:id="pausedList" styleClass="task-list" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

    <!-- BOTTOM -->
    <bottom>
        <HBox alignment="CENTER" spacing="16" styleClass="footer-bar">
            <padding><Insets bottom="10" top="10"/></padding>
            <Button onAction="#onRun" text="Run" styleClass="action-btn"/>
            <Button onAction="#onFinish" text="Finish" styleClass="action-btn"/>
            <Button onAction="#onDelete" text="Delete" styleClass="delete-btn"/>
        </HBox>
    </bottom>

</BorderPane>